# 👉 PUT YOUR BOT TOKEN HERE
BOT_TOKEN=YOUR_BOT_TOKEN

# 👉 PUT YOUR MONGODB CONNECTION STRING HERE
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/discord-bot

# 👉 PUT YOUR BOT CLIENT ID HERE
CLIENT_ID=YOUR_CLIENT_ID

# 👉 PUT YOUR GUILD ID HERE (for dev slash commands - leave empty for global)
GUILD_ID=YOUR_GUILD_ID

# 👉 PUT YOUR OPENWEATHER API KEY HERE (optional)
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY

# 👉 PUT YOUR MOD-LOGS CHANNEL ID HERE
MODLOGS_CHANNEL_ID=YOUR_MODLOGS_CHANNEL_ID

# 👉 PUT YOUR WELCOME CHANNEL ID HERE
WELCOME_CHANNEL_ID=YOUR_WELCOME_CHANNEL_ID

# 👉 PUT YOUR GOODBYE CHANNEL ID HERE
GOODBYE_CHANNEL_ID=YOUR_GOODBYE_CHANNEL_ID

# 👉 PUT YOUR TICKETS CATEGORY ID HERE
TICKETS_CATEGORY_ID=YOUR_TICKETS_CATEGORY_ID

# 👉 PUT YOUR TICKETS SUPPORT ROLE ID HERE
TICKETS_SUPPORT_ROLE_ID=YOUR_TICKETS_SUPPORT_ROLE_ID

# 👉 PUT YOUR TRANSCRIPTS CHANNEL ID HERE
TRANSCRIPTS_CHANNEL_ID=YOUR_TRANSCRIPTS_CHANNEL_ID

# 👉 PUT YOUR SUGGESTIONS CHANNEL ID HERE
SUGGESTIONS_CHANNEL_ID=YOUR_SUGGESTIONS_CHANNEL_ID

# 👉 PUT YOUR REPORTS CHANNEL ID HERE
REPORTS_CHANNEL_ID=YOUR_REPORTS_CHANNEL_ID

# 👉 PUT YOUR VERIFIED ROLE ID HERE
VERIFIED_ROLE_ID=YOUR_VERIFIED_ROLE_ID

# 👉 PUT YOUR AUTO-ROLE ID HERE (assigned on join)
AUTO_ROLE_ID=YOUR_AUTO_ROLE_ID

# 👉 PUT YOUR MUTED ROLE ID HERE
MUTED_ROLE_ID=YOUR_MUTED_ROLE_ID

# 👉 PUT YOUR TEMP VOICE CATEGORY ID HERE
TEMP_VOICE_CATEGORY_ID=YOUR_TEMP_VOICE_CATEGORY_ID

# 👉 PUT YOUR JOIN TO CREATE VOICE CHANNEL ID HERE
JOIN_TO_CREATE_CHANNEL_ID=YOUR_JOIN_TO_CREATE_CHANNEL_ID

# 👉 PUT YOUR GIVEAWAYS CHANNEL ID HERE
GIVEAWAYS_CHANNEL_ID=YOUR_GIVEAWAYS_CHANNEL_ID

# Environment (development or production)
NODE_ENV=development
